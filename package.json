{
  "name": "pspec",
  "version": "0.4.0",
  "description": "pspec (picospec) is the smallest specification toolkit for solo developers and AI agents",
  "main": "dist/index.js",
  "scripts": {
    "test": "jest",
    "build": "rm -rf dist && tsc && mkdir -p dist/templates/prompts && cp src/templates/prompts/*.md dist/templates/prompts/",
    "prepack": "npm run build",
    "report:budgets": "node dist/report-template-budgets.js"
  },
  "keywords": [
    "pspec",
    "spec",
    "sdd",
    "ai",
    "claude",
    "gemini",
    "cursor",
    "opencode",
    "roo",
    "kilo"
  ],
  "author": "rzkmak",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@types/node": "^25.5.2",
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "enquirer": "^2.4.1",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  },
  "bin": {
    "pspec": "./dist/index.js"
  },
  "repository": "https://github.com/rzkmak/pspec",
  "files": [
    "dist"
  ]
}
